# Copy to .env and fill in ONE provider to enable LIVE mode.
# With no keys, the system runs in deterministic MOCK mode and still works end-to-end.

# --- Option 1: Groq (FREE, recommended) -> https://console.groq.com/keys ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Option 2: Anthropic Claude (paid) ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Optional: reliable market data (price + fundamentals) ---
# Free key from https://site.financialmodelingprep.com/developer/docs (250 req/day).
# Without it, the app uses yfinance / Yahoo chart / synthetic fallback.
FMP_API_KEY=

PORT=8000
